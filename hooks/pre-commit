#!/usr/bin/env bash
set -euo pipefail

# Run on staged content only.
if git diff --cached -U0 | ./tools/redflag-scan.sh --fail >/dev/null 2>&1; then
  exit 0
fi

echo "[pre-commit] blocked: possible sensitive patterns detected in staged changes." >&2
echo "[pre-commit] tip: sanitize/redact, then re-stage and commit." >&2
exit 1
